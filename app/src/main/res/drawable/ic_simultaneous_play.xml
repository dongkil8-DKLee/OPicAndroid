<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="256"
    android:viewportHeight="256">

    <!--
        1.3x 확대 + 중앙 정렬:
        - 두 삼각형 bounding box: x(98~186), y(66~166) → 중심=(142,116)
        - pivotX/Y=142,116 에서 1.3x 스케일
        - translateX=-14, translateY=12 → 뷰포트 중심(128,128) 정렬
    -->
    <group
        android:pivotX="142"
        android:pivotY="116"
        android:scaleX="1.3"
        android:scaleY="1.3"
        android:translateX="-14"
        android:translateY="12">

        <!-- 뒤쪽 삼각형 (연한 주황 #FFB366) -->
        <path
            android:pathData="M110,90 L110,166 L186,128 Z"
            android:fillColor="#FFB366"/>

        <!-- 앞쪽 삼각형 (진한 주황 #FF8000) -->
        <path
            android:pathData="M98,66 L98,142 L174,104 Z"
            android:fillColor="#FF8000"/>

    </group>

</vector>
